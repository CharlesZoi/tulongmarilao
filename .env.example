# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase Chat Configuration (if different from main)
FIREBASE_CHAT_API_KEY=your_firebase_chat_api_key_here
FIREBASE_CHAT_AUTH_DOMAIN=your_chat_project.firebaseapp.com
FIREBASE_CHAT_PROJECT_ID=your_chat_project_id
FIREBASE_CHAT_STORAGE_BUCKET=your_chat_project.firebasestorage.app
FIREBASE_CHAT_MESSAGING_SENDER_ID=your_chat_sender_id
FIREBASE_CHAT_APP_ID=your_chat_app_id

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
USE_GOOGLE_MAPS=false